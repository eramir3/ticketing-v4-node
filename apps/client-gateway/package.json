{
  "name": "@org/client-gateway",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "npx nx serve client-gateway",
    "test": "npx nx test client-gateway"
  },
  "nx": {
    "name": "client-gateway",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "^build"
        ],
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--node-env=production"
          ],
          "cwd": "apps/client-gateway"
        },
        "configurations": {
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/client-gateway/dist/package.json",
          "{workspaceRoot}/apps/client-gateway/dist/package-lock.json"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/client-gateway/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "client-gateway:build",
          "runBuildTargetDependencies": true
        },
        "configurations": {
          "development": {
            "buildTarget": "client-gateway:build:development"
          },
          "production": {
            "buildTarget": "client-gateway:build:production"
          }
        }
      },
      "docker": {
        "executor": "nx:run-commands",
        "options": {
          "command": "minikube image build -t ticketing-v3-client-gateway -f apps/client-gateway/Dockerfile.dev . --alsologtostderr -v=1"
        }
      },
      "test": {
        "executor": "@nx/jest:jest",
        "options": {
          "jestConfig": "apps/client-gateway/jest.config.cts",
          "passWithNoTests": true
        }
      }
    }
  },
  "dependencies": {
    "@org/common": "*",
    "@org/errors": "*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0"
  }
}
